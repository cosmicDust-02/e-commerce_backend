{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Commerce Backend API",
    "description": "Node.js and Express-based e-commerce API with authentication, product management, shopping cart, and order processing",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "format": "ObjectId"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "resetToken": {
            "type": "string",
            "nullable": true
          },
          "resetTokenExpiration": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cart": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "itemId": {
                      "type": "string",
                      "format": "ObjectId"
                    },
                    "quantity": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              }
            }
          }
        },
        "required": ["email", "password"]
      },
      "Item": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "format": "ObjectId"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "price": {
            "type": "number",
            "format": "float",
            "minimum": 0
          },
          "image": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
          },
          "userId": {
            "type": "string",
            "format": "ObjectId"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["title", "price", "image", "description"]
      },
      "Order": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "format": "ObjectId"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "item": {
                  "$ref": "#/components/schemas/Item"
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "user": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "format": "email"
              },
              "userId": {
                "type": "string",
                "format": "ObjectId"
              }
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "userId": {
            "type": "string",
            "format": "ObjectId"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "CartItem": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string",
            "format": "ObjectId"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "msg": {
                  "type": "string"
                },
                "param": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User Login",
        "description": "Authenticates a user and returns a JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 5,
                    "example": "password123"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/signup": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User Registration",
        "description": "Creates a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "newuser@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 5,
                    "example": "password123"
                  },
                  "confirmPassword": {
                    "type": "string",
                    "format": "password",
                    "minLength": 5,
                    "example": "password123"
                  }
                },
                "required": ["email", "password", "confirmPassword"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error - email already exists or passwords don't match",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reset": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Request Password Reset",
        "description": "Sends a password reset link to the user's email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@example.com"
                  }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/reset/{token}": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Update Password with Reset Token",
        "description": "Updates user password using a valid reset token",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 5,
                    "example": "newpassword123"
                  },
                  "confirmPassword": {
                    "type": "string",
                    "format": "password",
                    "minLength": 5,
                    "example": "newpassword123"
                  }
                },
                "required": ["password", "confirmPassword"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated successfully"
          },
          "400": {
            "description": "Invalid or expired token"
          }
        }
      }
    },
    "/items": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get All Items",
        "description": "Fetches all available items in the shop (public endpoint)",
        "responses": {
          "200": {
            "description": "List of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "get": {
        "tags": ["Shop"],
        "summary": "Get Item Details",
        "description": "Fetches details for a specific item",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "404": {
            "description": "Item not found"
          }
        }
      }
    },
    "/cart": {
      "get": {
        "tags": ["Cart"],
        "summary": "Get Cart Items",
        "description": "Retrieves all items in the user's cart",
        "responses": {
          "200": {
            "description": "User's cart",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CartItem"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/add-to-cart/{id}": {
      "post": {
        "tags": ["Cart"],
        "summary": "Add Item to Cart",
        "description": "Adds an item to the user's cart or increments quantity if already present",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Item added to cart successfully"
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "404": {
            "description": "Item not found"
          }
        }
      }
    },
    "/delete-from-cart/{id}": {
      "delete": {
        "tags": ["Cart"],
        "summary": "Remove Item from Cart",
        "description": "Removes an item from the user's cart",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Item removed from cart successfully"
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "404": {
            "description": "Item not in cart"
          }
        }
      }
    },
    "/create-order": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create Order",
        "description": "Creates a new order from items in the user's cart",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Cart is empty"
          },
          "401": {
            "description": "Unauthorized - token required"
          }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get User Orders",
        "description": "Fetches all orders for the authenticated user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of user orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token required"
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get Order Invoice",
        "description": "Generates and downloads an invoice for a specific order",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice PDF file",
            "content": {
              "application/pdf": {}
            }
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "403": {
            "description": "Forbidden - order does not belong to user"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/admin/add-item": {
      "post": {
        "tags": ["Admin"],
        "summary": "Create Item",
        "description": "Creates a new product item (admin only)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Laptop"
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "minimum": 0,
                    "example": 999.99
                  },
                  "description": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 100,
                    "example": "High performance laptop"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image (PNG, JPG, JPEG only)"
                  }
                },
                "required": ["title", "price", "description", "image"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid image format"
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/items": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get Admin Items",
        "description": "Fetches all items created by the authenticated admin",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of admin's items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token required"
          }
        }
      }
    },
    "/admin/edit-item/{id}": {
      "put": {
        "tags": ["Admin"],
        "summary": "Update Item",
        "description": "Updates an existing item (admin only)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Updated Laptop"
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "minimum": 0,
                    "example": 1099.99
                  },
                  "description": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 100,
                    "example": "Updated description"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image (PNG, JPG, JPEG only)"
                  }
                },
                "required": ["title", "price", "description"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "403": {
            "description": "Forbidden - item does not belong to user"
          },
          "404": {
            "description": "Item not found"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/delete-item/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete Item",
        "description": "Deletes a product item (admin only)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ObjectId"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Item deleted successfully"
          },
          "401": {
            "description": "Unauthorized - token required"
          },
          "403": {
            "description": "Forbidden - item does not belong to user"
          },
          "404": {
            "description": "Item not found"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and password management"
    },
    {
      "name": "Shop",
      "description": "Public shop endpoints for browsing items"
    },
    {
      "name": "Cart",
      "description": "Shopping cart management"
    },
    {
      "name": "Orders",
      "description": "Order creation and retrieval"
    },
    {
      "name": "Admin",
      "description": "Admin endpoints for product management"
    }
  ]
}
